<h1><%- title %></h1>
<%- messages() %>
<% if (errors) { %>
  <ul id="messages">
 <% errors.array().forEach(error => { %>
   <li class="error"><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>

<form class="form-container"  action="/inv/add-classification" method="POST">
     <p class=hint>All fields are required.</p>
        <label for="classification_name">Classification Name</label>
        <span>Must be alphabetic characters only.</span>
        <input type="text" id="classification_name" name="classification_name" required placeholder="Enter classification name">
    <button type="submit" >Add Classification</button>
</form>
