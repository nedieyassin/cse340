<h1><%- title %></h1>
<%- messages() %>
    <% if (errors) { %>
        <ul id="messages">
            <% errors.array().forEach(error=> { %>
                <li class="error">
                    <%= error.msg %>
                </li>
                <% }) %>
        </ul>
        <% } %>

            <form id="updateForm" class="form-container" action="/inv/update" method="POST">

                <input type="hidden" name="inv_id"
<% if(locals.inv_id) { %> value="<%= locals.inv_id %>"
<% } %>>

                        <p class=hint>All fields are required.</p>



                        <label for="classification_id">Classification:</label>

                        <%- classificationSelect %>

                            <label for="inv_make">Make:</label>
                            <span>Must be alphanumeric characters only.</span>
                            <input type="text" id="inv_make" name="inv_make" required value="<%= locals.inv_make %>">

                            <label for="inv_model">Model:</label>
                            <span>Must be alphanumeric characters only.</span>
                            <input type="text" id="inv_model" name="inv_model" required value="<%= locals.inv_model %>">


                            <label for="inv_description">Description:</label>
                            <textarea id="inv_description" name="inv_description"
                                required><%= locals.inv_description %></textarea>

                            <label for="inv_image">Image Path:</label>
                            <input type="text" id="inv_image" name="inv_image" required
                                placeholder="/images/vehicles/no-image.png" value="<%= locals.inv_image %>">

                            <label for="inv_thumbnail">Thumbnail Path:</label>
                            <input type="text" id="inv_thumbnail" name="inv_thumbnail" required
                                placeholder="/images/vehicles/no-image-tn.png" value="<%= locals.inv_thumbnail %>">


                            <label for="inv_price">Price:</label>
                            <span>Must be a positive number, can include decimals.</span>
                            <input type="number" id="inv_price" name="inv_price" min="0" step="0.01"
                                placeholder="decimal or integer" required value="<%= locals.inv_price %>">

                            <label for="inv_year">Year:</label>
                            <span>Must be a four-digit number between 1886 and 2099.</span>
                            <input type="number" id="inv_year" name="inv_year" min="1886" max="2099" required
                                value="<%= locals.inv_year %>">


                            <label for="inv_miles">Miles:</label>
                            <span>Must be a positive number.</span>
                            <input type="number" id="inv_miles" name="inv_miles" min="0" placeholder="digits only"
                                required value="<%= locals.inv_miles %>">


                            <label for="inv_color">Color:</label>
                            <span>Must be a valid color.</span>
                            <input type="text" id="inv_color" name="inv_color" required value="<%= locals.inv_color %>">

                            <button type="submit" disabled>Update Vehicle</button>
            </form>

            <script src="../../js/inv-update.js"></script>