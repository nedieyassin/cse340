<h1><%- title %></h1>
<%- messages() %>
    <% if (errors) { %>
        <ul id="messages">
            <% errors.array().forEach(error=> { %>
                <li class="error">
                    <%= error.msg %>
                </li>
                <% }) %>
        </ul>
        <% } %>

            <form id="updateForm" class="form-container" action="/inv/delete" method="POST">

                <input type="hidden" name="inv_id" <% if(locals.inv_id) { %> value="<%= locals.inv_id %>"
                    <% } %>>



                        <label for="inv_make">Make:</label>
                        <input type="text" id="inv_make" name="inv_make" required readonly value="<%= locals.inv_make %>">

                        <label for="inv_model">Model:</label>
                        <input type="text" id="inv_model" name="inv_model" required readonly value="<%= locals.inv_model %>">



                        <label for="inv_price">Price:</label>
                        <input type="number" id="inv_price" name="inv_price" min="0" step="0.01"
                            placeholder="decimal or integer" required readonly value="<%= locals.inv_price %>">

                        <label for="inv_year">Year:</label>
                        <input type="number" id="inv_year" name="inv_year" min="1886" max="2099" readonly required
                            value="<%= locals.inv_year %>">

                        <p>Confirm Deletion - The delete is permanent.</p>

                        <button type="submit">Delete Vehicle</button>
            </form>
 